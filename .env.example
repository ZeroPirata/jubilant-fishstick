# =============================================================================
# SERVER
# =============================================================================
SERVER_HOST=localhost
SERVER_PORT=8080
CORS_ALLOWED_ORIGIN=https://seu-dominio.com

# =============================================================================
# PROJECT
# =============================================================================
PROJECT_NAME=hackton-treino
VERSION=0.1.0
DEBUG=false
LOGGER_FOLDER=tmp
CONTEXT_TIMEOUT=30s

# =============================================================================
# TLS
# =============================================================================
TLS_ENABLED=false
TLS_CERT_FILE=
TLS_KEY_FILE=
TLS_CA_FILE=

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=desafio_db
POSTGRES_SSL_MODE=disable
POSTGRES_MAX_CONNECTIONS=10
POSTGRES_MIN_CONNECTIONS=1
POSTGRES_MAX_CONN_LIFETIME=30m
POSTGRES_MAX_CONN_IDLE_TIME=5m
POSTGRES_HEALTH_CHECK_PERIOD=30s
POSTGRES_CONNECT_TIMEOUT=5s

# =============================================================================
# REDIS
# =============================================================================
REDIS_ADDR=cache:6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# HASH (Argon2id) — gere com: openssl rand -base64 32
# =============================================================================
HASH_ARGON2_PEPPER=changeme
HASH_ARGON2_MEMORY=32768
HASH_ARGON2_PARALLELISM=1
HASH_ARGON2_ITERATIONS=3
HASH_ARGON2_SALT_LEN=16
HASH_ARGON2_KEY_LEN=32

# =============================================================================
# AI (LLM principal)
# =============================================================================
API_PROVIDER=gemini
API_KEY_AI=your_api_key_here
API_MODEL_AI=gemini-2.5-flash-lite
API_URL_AI=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent
API_AI_TIMEOUT=30s

# =============================================================================
# SCRAPE AI
# =============================================================================
SCRAPE_AI_ACTIVATE=false
SCRAPE_AI_PROVIDER=ollama
SCRAPE_AI_KEY=
SCRAPE_AI_MODEL=phi4
SCRAPE_AI_URL=http://localhost:11434/v1/chat/completions
SCRAPE_AI_TIMEOUT=5m

# =============================================================================
# WORKER
# =============================================================================
WORKER_MAX_CONCURRENT=5   # goroutines simultâneas (gargalo real: rate limit da LLM, não CPU)
WORKER_BATCH_SIZE=20      # jobs buscados por tick
WORKER_INTERVAL=30s       # intervalo entre verificações de jobs pendentes

# =============================================================================
# JWT — gere com: openssl rand -base64 32
# =============================================================================
JWT_SECRET=changeme
JWT_EXPIRATION=24h
